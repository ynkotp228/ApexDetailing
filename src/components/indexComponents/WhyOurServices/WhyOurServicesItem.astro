---
import { Picture } from "astro:assets";

const { title, description, image, alt } = Astro.props;
---

<article
    class="group relative flex min-h-96 flex-col justify-end overflow-hidden
           rounded-lg shadow-lg ring-1 ring-carbon-900/5 sm:min-h-112"
>
    <Picture
        class="media-bg transition-transform duration-700 ease-out group-hover:scale-105"
        src={image}
        alt={alt}
        widths={[320, 540, 720]}
        sizes="(min-width: 768px) 50vw, 100vw"
        formats={['avif', 'webp']}
        loading="lazy"
    />

    <!-- Градієнт для читабельності тексту поверх фону -->
    <div
        class="absolute inset-0 bg-linear-to-t from-carbon-900/95 via-carbon-900/55 to-carbon-900/5"
        aria-hidden="true"
    >
    </div>

    <div class="relative z-10 p-7 text-white sm:p-8">
        <h3 class="font-display text-2xl font-bold tracking-tight">
            {title}
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-white/85">
            {description}
        </p>
    </div>
</article>
