---
import WhyOurServicesItem from "./WhyOurServicesItem.astro";
import services1 from "../../../assets/images/MainPageImages/services/services1.webp";
import services2 from "../../../assets/images/MainPageImages/services/services2.webp";
import services3 from "../../../assets/images/MainPageImages/services/services3.webp";
import services4 from "../../../assets/images/MainPageImages/services/services4.webp";

const services = [
    {
        alt: "Зображення чистого боксу для автомобіля",
        title: "Лабораторна чистота",
        description: "Наші бокси захищені від пилу та мають закритий контур вентиляції. Це критично для правильної адгезії кераміки та бездоганного нанесення антигравійної плівки без повітряних бульбашок.",
        image: services1,
    },
    {   
        alt: "Зобраення боксу із технологічним освітленням",    
        title: "Контроль світла Scangrip",
        description: "Використовуємо професійне інспекційне світло з різною колірною температурою. Це дозволяє майстру побачити й усунути навіть найменші голограми, які непомітні під звичайними лампами.",
        image: services2,
    },
    {   
        alt: "Зображення високоточного вимірювального пристрою",
        title: "Вимірювання мікронів",
        description: "Перед початком полірування ми обов'язково вимірюємо товщину лакофарбового покриття ультразвуковим товщиноміром. Ми працюємо безпечно та зберігаємо максимальний шар рідного лаку.",
        image: services3,
    },
    {   
        alt: "Зображення преміальної хімії для обробки автомобіля",
        title: "Преміальна хімія",
        description: "Жодних мас-маркет засобів. Лише сертифіковані європейські та американські бренди: Koch-Chemie, Gtechniq, CarPro та хімічно стійкі поліуретанові плівки преміум-сегменту.",
        image: services4,
    }

]

---

<section class="bg-clinic-100 py-20 sm:py-24">
    <div class="container-x">
        <div class="mx-auto max-w-2xl text-center">
            <p class="section-eyebrow">Наші переваги</p>
            <h2 class="section-title mt-3">
                Чому люди обирають саме «Apex&nbsp;Detailing»?
            </h2>
            <p class="mt-4 text-base leading-relaxed text-carbon-700/80">
                Технологічний підхід, сертифіковані матеріали та контроль якості на кожному етапі.
            </p>
        </div>

        <div class="mt-14 grid gap-6 md:grid-cols-2">
            {services.map(service => <WhyOurServicesItem {...service} />)}
        </div>
    </div>
</section>