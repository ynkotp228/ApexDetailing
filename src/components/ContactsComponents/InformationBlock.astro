---
import { Picture } from "astro:assets";
import informationBlockImg from '../../assets/images/ContactsPageImages/informationBlockImg.webp';
---

<section class="relative flex min-h-[60vh] items-center overflow-hidden">
    <Picture
        class="media-bg"
        src={informationBlockImg}
        alt="Зображення роботи нашого спеціаліста над автомобілем"
        widths={[240, 540, 720, 1040, informationBlockImg.width]}
        sizes="100vw"
        formats={['avif', 'webp']}
        loading="eager"
    />

    <!-- Затемнення зліва, де розміщено текст -->
    <div
        class="absolute inset-0 bg-linear-to-r from-carbon-900/90 via-carbon-900/60 to-transparent"
        aria-hidden="true"
    >
    </div>

    <div class="relative z-10 container-x py-20">
        <div class="max-w-xl text-white">
            <p class="section-eyebrow text-cobalt-100">Контакти</p>
            <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
                Чекаємо на ваше авто в Apex Detailing
            </h1>
            <p class="mt-5 text-base leading-relaxed text-white/80 sm:text-lg">
                Завітайте на безкоштовну діагностику стану лакофарбового покриття та консультацію майстра.
            </p>
            <a href="#form" class="btn-primary mt-8">
                Залишити заявку
            </a>
        </div>
    </div>
</section>
