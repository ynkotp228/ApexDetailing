---
---

<section id="form" class="bg-clinic-200 py-20 sm:py-24">
	<div class="container-x">
		<div class="mx-auto max-w-2xl">
			<div class="text-center">
				<p class="section-eyebrow">Зворотний зв'язок</p>
				<h2 class="section-title mt-3">Маєте запитання?</h2>
				<p class="mt-4 text-base leading-relaxed text-carbon-700/80">
					Залиште свої контакти — і ми зв'яжемося з вами найближчим часом.
				</p>
			</div>

			<form
				id="ask-form"
				action="#@"
				method="POST"
				class="mt-10 rounded-lg border border-carbon-900/10 bg-clinic-50 p-6 shadow-lg sm:p-8"
				novalidate
			>
				<div class="grid gap-5 sm:grid-cols-2">
					<div>
						<label for="name" class="field-label">Ваше ім'я</label>
						<input
							type="text"
							id="name"
							name="name"
							minlength="2"
							required
							placeholder="Мінімум 2 символи"
							class="field"
						/>
						<p class="field-error" data-error-for="name" hidden></p>
					</div>

					<div>
						<label for="tel" class="field-label">Ваш телефон</label>
						<input
							type="tel"
							id="tel"
							name="tel"
							pattern="\+380\d{9}"
							required
							placeholder="+380XXXXXXXXX"
							class="field"
						/>
						<p class="field-error" data-error-for="tel" hidden></p>
					</div>

					<div class="sm:col-span-2">
						<label for="message" class="field-label">Введіть марку автомобіля</label>
						<textarea
							id="message"
							name="message"
							rows="2"
							required
							placeholder="BMW M4 2023 / Audi Q7 2021"
							class="field resize-y"
						></textarea>
						<p class="field-error" data-error-for="message" hidden></p>
					</div>

					<div class="sm:col-span-2">
						<label for="option" class="field-label">Що саме вас цікавить?</label>
						<select id="option" name="option" required class="field">
							<option value="nothing" disabled selected>Оберіть послугу з списку</option>
							<option value="Comprehensive bodywork polishing">Комплексне полірування кузова</option>
							<option value="Application of 9H nanoceramics">Нанесення нанокераміки 9H</option>
							<option value="Stone chip protection film (Full protection)">Антигравійна плівка (Повний захист)</option>
							<option value="Stone chip protection film (Partial protection)">Антигравійна плівка (Зона ризику)</option>
							<option value="Deep interior cleaning">Глибока хімчистка салону</option>
							<option value="Pre-sale preparation">Передпродажна підготовка</option>
							<option value="I need advice from a professional">Потрібна консультація майстра</option>
						</select>
						<p class="field-error" data-error-for="option" hidden></p>
					</div>
				</div>

				<button type="submit" class="btn-primary mt-6 w-full">Надіслати</button>
				<p
					id="form-status"
					role="status"
					aria-live="polite"
					hidden
					class="mt-4 rounded-lg px-4 py-3 text-center text-sm font-medium
					       data-[state=ok]:bg-green-50 data-[state=ok]:text-green-700
					       data-[state=error]:bg-red-50 data-[state=error]:text-red-700"
				></p>
			</form>
		</div>
	</div>
</section>

<script>
	const form = document.getElementById("ask-form") as HTMLFormElement | null;
	const status = document.getElementById("form-status");

	if (form && status) {
		const optionInput = form.elements.namedItem("option") as HTMLSelectElement;
		const nameInput = form.elements.namedItem("name") as HTMLInputElement;
		const telInput = form.elements.namedItem("tel") as HTMLInputElement;
		const messageInput = form.elements.namedItem("message") as HTMLTextAreaElement;

		const show = (msg: string, ok: boolean) => {
			status.textContent = msg;
			status.hidden = false;
			status.dataset.state = ok ? "ok" : "error";
		};

		const setFieldError = (input: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement, msg: string) => {
			const errorEl = form.querySelector<HTMLElement>(`[data-error-for="${input.name}"]`);
			if (msg) {
				if (errorEl) {
					errorEl.textContent = msg;
					errorEl.hidden = false;
				}
				input.setAttribute("aria-invalid", "true");
			} else {
				if (errorEl) {
					errorEl.textContent = "";
					errorEl.hidden = true;
				}
				input.removeAttribute("aria-invalid");
			}
		};

		const validateName = (): string => {
			const value = nameInput.value.trim();
			if (!value) return "Будь ласка, введіть ваше ім'я.";
			if (value.length < 2) return "Ім'я має містити щонайменше 2 символи.";
			return "";
		};

		const validateTel = (): string => {
			const value = telInput.value.trim();
			if (!value) return "Будь ласка, введіть номер телефону.";
			if (!/^\+380\d{9}$/.test(value)) {
				return "Невірний формат. Введіть номер у вигляді +380XXXXXXXXX (12 цифр).";
			}
			return "";
		};

		const validateMessage = (): string => {
			const value = messageInput.value.trim();
			if (!value) return "Будь ласка, опишіть ваше запитання.";
			if (value.length < 2) {
				return `Повідомлення занадто коротке (мінімум 2 символів, зараз ${value.length}).`;
			}
			return "";
		};

		const validateOption = (): string => {
			const value = optionInput.value;
			if (!value || value === "nothing") return "Будь ласка, оберіть послугу зі списку.";
			return "";
		};

		telInput.addEventListener("focus", () => {
			if (!telInput.value) telInput.value = "+380";
		});

		telInput.addEventListener("blur", () => {
			if (telInput.value === "+380") telInput.value = "";
		});

		nameInput.addEventListener("blur", () => setFieldError(nameInput, validateName()));
		nameInput.addEventListener("input", () => {
			if (nameInput.getAttribute("aria-invalid")) setFieldError(nameInput, validateName());
		});

		telInput.addEventListener("blur", () => {
			if (telInput.value) setFieldError(telInput, validateTel());
		});
		telInput.addEventListener("input", () => {
			if (telInput.getAttribute("aria-invalid")) setFieldError(telInput, validateTel());
		});

		messageInput.addEventListener("blur", () => setFieldError(messageInput, validateMessage()));
		messageInput.addEventListener("input", () => {
			if (messageInput.getAttribute("aria-invalid")) setFieldError(messageInput, validateMessage());
		});
		optionInput.addEventListener("change", () => setFieldError(optionInput, validateOption()));
		form.addEventListener("submit", async (e) => {
			e.preventDefault();

			const errors = {
				name: validateName(),
				tel: validateTel(),
				message: validateMessage(),
				option: validateOption(),
			};
			setFieldError(nameInput, errors.name);
			setFieldError(telInput, errors.tel);
			setFieldError(messageInput, errors.message);
			setFieldError(optionInput, errors.option);

			const firstInvalid = [nameInput, telInput, messageInput, optionInput].find(
				(input) => input.getAttribute("aria-invalid"),
			);
			if (firstInvalid) {
				show("Будь ласка, виправте помилки у формі.", false);
				firstInvalid.focus();
				return;
			}

			const data = new FormData(form);
			try {
				const res = await fetch(form.action, {
					method: "POST",
					body: data,
					headers: { Accept: "application/json" },
				});
				if (res.ok) {
					show("Дякуємо! Ваше повідомлення надіслано.", true);
					form.reset();
				} else {
					show("Не вдалося надіслати. Спробуйте пізніше.", false);
				}
			} catch {
				show("Помилка мережі. Перевірте з'єднання.", false);
			}
		});
	}
</script>
