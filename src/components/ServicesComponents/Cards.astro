---
import CardItem from "./CardItem.astro"
import priceImage1 from "../../assets/images/ServicesPageImages/priceImage1.webp";
import priceImage2 from "../../assets/images/ServicesPageImages/priceImage2.webp";
import priceImage3 from "../../assets/images/ServicesPageImages/priceImage3.webp";
import priceImage4 from "../../assets/images/ServicesPageImages/priceImage4.webp";
import priceImage5 from "../../assets/images/ServicesPageImages/priceImage5.webp";

const services = [
  {
    alt: "Зображення працівника який полірує кузов автомобіля",
    img: priceImage1,
    id: "polishing",
    title: "Відновлювальне полірування кузова",
    price: "від 8 000 грн",
    duration: "1.5 – 2 дні",
    shortDesc: "Видалення до 90% подряпин, павутинки від мийок та оксидованого шару. Повернення дзеркального блиску.",
    fullFeatures: [
      "3-етапна деконтамінація кузова (очищення від бітуму, смол, глини та залізистих вкраплень)",
      "Обов'язкове вимірювання товщини ЛФП ультразвуковим товщиноміром на кожній деталі",
      "Маскування всіх гумових, пластикових елементів та ребер кузова захисною стрічкою",
      "Дво- або трикрокове полірування пастами різної зернистості (роторні та ексцентрикові машинки)",
      "Фінішний антиголограмний етап під інспекційним світлом Scangrip з різною температурою",
      "Глибоке очищення та полірування передньої й задньої оптики автомобіля"
    ]
  },
  {
    alt: "Зображення працівника який наносить нанокераміку",
    img: priceImage2,
    id: "ceramics",
    title: "Нанесення нанокераміки 9H",
    price: "від 12 000 грн",
    duration: "24 – 48 год",
    shortDesc: "Надміцне молекулярне захисне покриття лаку. Максимальний гідрофоб, захист від хімії та вигорання.",
    fullFeatures: [
      "Глибоке хімічне знежирення кузова та підготовка лаку спеціальними активаторами адгезії",
      "Нанесення базового підкладкового шару (Primer) для максимального зчеплення складу з лаком",
      "Пошарове ручне нанесення основного керамічного складу підвищеної твердості 9H",
      "Нанесення фінішного топового шару (Top Coat) для екстремального глянцю та дзеркального ефекту",
      "Запікання та повна кристалізація покриття під інфрачервоними сушками у закритому боксі",
      "Видача фірмового гарантійного талона на покриття терміном від 12 місяців"
    ]
  },
  {   
    alt: "Зображення працівника який обклеює автомобіль антигравійною плівкою",
    img: priceImage3,
    id: "ppf-film",
    title: "Обклеювання антигравійною плівкою (PPF)",
    price: "від 25 000 грн",
    duration: "3 – 5 днів",
    shortDesc: "Броня для автомобіля від сколів, гравію та притирань. Преміальний поліуретан із функцією самовідновлення.",
    fullFeatures: [
      "Делікатний демонтаж заважаючих елементів (ручки дверей, емблеми, молдинги) для завороту плівки",
      "Хірургічна підготовка та знежирення країв деталей ізопропіловим спиртом",
      "Вирізка лекал за точними цифровими базами даних на плотері під конкретну модель та комплектацію",
      "Нанесення преміальної поліуретанової плівки завтовшки 150-200 мікрон на спеціальний гель",
      "Виведення мильної основи та залишків вологи професійними ракелями без заломів плівки",
      "Фінальний термозахист країв (активація клейового шару) та суворий контроль стиків"
    ]
  },
  { 
    alt: "Зображення працівника який вичищає салон автомобіля",
    img: priceImage4,
    id: "interior-detailing",
    title: "Глибока хімчистка салону з демонтажем",
    price: "від 6 000 грн",
    duration: "1 – 1.5 дні",
    shortDesc: "Абсолютна стерильність салону. Видалення застарілих плям, бруду та запахів гіпоалергенною преміум-хімією.",
    fullFeatures: [
      "Повний акуратний демонтаж сидінь для 100% доступу до ковроліну та прихованих зон",
      "Глибоке вакуумне очищення та видування пилу з важкодоступних місць пістолетом Tornador",
      "Екстракторна (волога) чистка підлоги, килимків, стелі та тканинної оббивки під тиском",
      "Делікатне ручне очищення шкіряних елементів м'якими щітками та консервація преміум-кремами",
      "Очищення парою вентиляційних каналів, дефлекторів, ременів безпеки та стиків пластику",
      "Фінішне озонування салону генератором озону для знищення бактерій, спор цвілі та запахів"
    ]
  },
  { 
    alt: "Зображення очистки мотора та куззова автомобіля перед продажем",
    img: priceImage5,
    id: "pre-sale",
    title: "Передпродажна підготовка автомобіля",
    price: "від 4 500 грн",
    duration: "8 – 12 годин",
    shortDesc: "Експрес-комплекс для максимального підвищення ринкової вартості автомобіля перед продажем.",
    fullFeatures: [
      "Експрес-полірування кузова в один крок (One-Step) для зняття нальоту та надання яскравого глянцю",
      "Безпечна мийка моторного відсіку спеціальним діелектричним гелем та консервація пластику",
      "Ретельне сухе прибирання салону, очищення скла без розводів та матування пластикових панелей",
      "Очищення від нагару та ручне дзеркальне полірування металевих насадок вихлопної системи",
      "Очищення колісних дисків від гальмівного пилу та чорніння гуми стійкими преміум-складами",
      "Локальне масування дрібних відколів на капоті та бампері оригінальною фарбою в колір авто"
    ]
  }
];
---

<section id="prices" class="bg-clinic-100 py-20 sm:py-24">
    <div class="container-x">
        <div class="mx-auto max-w-2xl text-center">
            <p class="section-eyebrow">Прайс-лист</p>
            <h2 class="section-title mt-3">Наші комплекси та ціни</h2>
            <p class="mt-4 text-base leading-relaxed text-carbon-700/80">
                Натисніть на послугу, щоб дізнатися, що саме входить у вартість.
            </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl space-y-4">
            {services.map((service, i) => <CardItem {...service} reverse={i % 2 === 1} />)}
        </div>
    </div>
</section>