---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
    img: ImageMetadata;
    title: string;
    id: string;
    price: string;
    duration: string;
    shortDesc: string;
    fullFeatures: string[];
    reverse?: boolean;
}
const { title, id, price, img, duration, shortDesc, fullFeatures, reverse = false } = Astro.props;
---
<details
    id={id}
    class="group overflow-hidden rounded-lg border border-carbon-900/10 bg-clinic-50 shadow-sm
           transition hover:border-cobalt-500/40 hover:shadow-md
           open:border-cobalt-500/50 open:shadow-md"
>
    <summary
        class="flex cursor-pointer list-none flex-col gap-5 p-4 sm:flex-row sm:items-center sm:gap-6 sm:p-5
               [&::-webkit-details-marker]:hidden"
    >
        <!-- Фото послуги (чергується зліва / справа) -->
        <div class:list={["shrink-0", reverse && "sm:order-2"]}>
            <Image
                src={img}
                alt={title}
                class="h-48 w-full rounded-lg object-cover sm:h-40 sm:w-40"
            />
        </div>

        <!-- Контент + ціна -->
        <div class="flex flex-1 flex-col gap-3 sm:flex-row sm:items-center sm:justify-between sm:gap-6">
            <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                    <span class="font-display text-lg font-bold text-carbon-900 sm:text-xl">
                        {title}
                    </span>
                    <span class="inline-flex items-center rounded-full bg-clinic-200 px-2.5 py-0.5 text-xs font-medium text-carbon-700">
                        {duration}
                    </span>
                </div>
                <p class="mt-2 text-sm leading-relaxed text-carbon-700/80">
                    {shortDesc}
                </p>
            </div>

            <div class="flex shrink-0 items-center gap-3 sm:flex-col sm:items-end sm:gap-2">
                <span class="whitespace-nowrap font-display text-lg font-bold text-cobalt-600">
                    {price}
                </span>
                <svg
                    class="h-5 w-5 text-carbon-700/50 transition-transform duration-300 group-open:rotate-180"
                    xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </div>
        </div>
    </summary>

    <div class="border-t border-carbon-900/10 px-5 pb-6 pt-4 sm:px-6">
        <p class="text-sm font-semibold text-carbon-900">Що конкретно входить у вартість процесу:</p>
        <ul class="mt-3 space-y-2.5">
            {fullFeatures.map(feature => (
                <li class="flex gap-3 text-sm leading-relaxed text-carbon-700/90">
                    <svg
                        class="mt-0.5 h-4 w-4 shrink-0 text-cobalt-500"
                        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span>{feature}</span>
                </li>
            ))}
        </ul>
    </div>
</details>
